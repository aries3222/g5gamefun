<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Gloria 的默書小遊戲</title>
    <style>
        :root { --primary: #ff7675; --secondary: #74b9ff; --bg: #f0f2f5; }
        body { font-family: 'Comic Sans MS', 'Microsoft JhengHei', sans-serif; background: var(--bg); display: flex; justify-content: center; padding: 20px; }
        #game-box { background: white; width: 100%; max-width: 500px; border-radius: 20px; padding: 30px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 4px solid var(--secondary); }
        h1 { color: var(--primary); font-size: 24px; }
        .zone { margin: 20px 0; padding: 15px; border: 2px dashed #ccc; min-height: 50px; border-radius: 10px; }
        .word-card { display: inline-block; padding: 8px 15px; margin: 5px; background: var(--secondary); color: white; border-radius: 20px; cursor: pointer; transition: 0.2s; }
        .word-card:hover { transform: scale(1.1); background: #0984e3; }
        .btn { background: var(--primary); color: white; border: none; padding: 10px 25px; border-radius: 50px; font-size: 18px; cursor: pointer; margin-top: 20px; }
        .btn:disabled { background: #ccc; }
        #msg { height: 30px; margin-top: 10px; font-weight: bold; color: #2d3436; }
        .speaker { font-size: 24px; cursor: pointer; margin-left: 10px; }
    </style>
</head>
<body>

<div id="game-box">
    <h1>🎒 Dictation 16 溫習遊戲</h1>
    <p>Gloria, 請把單字拖/按到下方框框排好：</p>
    
    <div id="q-text" style="font-weight: bold; color: #636e72;"></div>
    
    <div id="pool" class="zone"></div>
    
    <div id="answer" class="zone"></div>

    <div id="msg">點擊單字開始！</div>
    
    <button class="btn" id="nextBtn" onclick="loadNext()" disabled>下一題 ➔</button>
    <div style="margin-top:20px; font-size: 14px; color: #b2bec3;">目標：Part A & B</div>
</div>

<script>
    const questions = [
        { q: "What is your name?", words: ["What", "is", "your", "name?"] },
        { q: "My name is Dan.", words: ["My", "name", "is", "Dan."] },
        { q: "How do you do?", words: ["How", "do", "you", "do?"] },
        { q: "I walk over the flowers.", words: ["I", "walk", "over", "the", "flowers."] },
        { q: "I jump on the grass.", words: ["I", "jump", "on", "the", "grass."] },
        { q: "You can catch me.", words: ["You", "can", "catch", "me."] },
        { q: "hills", words: ["hills"], hint: "⛰️" },
        { q: "mountains", words: ["mountains"], hint: "🏔️" },
        { q: "the moon", words: ["the", "moon"], hint: "🌙" },
        { q: "the sun", words: ["the", "sun"], hint: "☀️" }
    ];

    let currentIdx = 0;
    let currentAns = [];

    function speak(text) {
        const msg = new SpeechSynthesisUtterance();
        msg.text = text;
        msg.lang = 'en-US';
        window.speechSynthesis.speak(msg);
    }

    function loadNext() {
        if (currentIdx >= questions.length) {
            document.getElementById('game-box').innerHTML = "<h1>🎉 完咗喇！</h1><p>Gloria 真棒！默書加油！</p><button class='btn' onclick='location.reload()'>再玩一次</button>";
            return;
        }

        const q = questions[currentIdx];
        document.getElementById('q-text').innerHTML = q.hint ? `單字挑戰：${q.hint}` : "重組句子：";
        document.getElementById('answer').innerHTML = "";
        document.getElementById('msg').innerText = "點擊單字排列";
        document.getElementById('msg').style.color = "#2d3436";
        document.getElementById('nextBtn').disabled = true;
        currentAns = [];

        let shuffled = [...q.words].sort(() => Math.random() - 0.5);
        const pool = document.getElementById('pool');
        pool.innerHTML = "";
        
        shuffled.forEach(w => {
            const span = document.createElement('div');
            span.className = 'word-card';
            span.innerText = w;
            span.onclick = function() {
                moveWord(this, q.words.length, q.q);
            };
            pool.appendChild(span);
        });
    }

    function moveWord(el, targetLen, correctStr) {
        const answerZone = document.getElementById('answer');
        answerZone.appendChild(el);
        currentAns.push(el.innerText);
        el.onclick = null; // 防止重複點擊

        if (currentAns.length === targetLen) {
            if (currentAns.join(" ") === correctStr) {
                document.getElementById('msg').innerText = "✅ Correct! 答對了！";
                document.getElementById('msg').style.color = "green";
                document.getElementById('nextBtn').disabled = false;
                speak(correctStr);
                currentIdx++;
            } else {
                document.getElementById('msg').innerText = "❌ Try again! 再試試！";
                document.getElementById('msg').style.color = "red";
                setTimeout(loadNext, 1000);
            }
        }
    }

    // 初始化
    loadNext();
</script>

</body>
</html>
