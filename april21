<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>小一英文温習 - Nature Vocabulary</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@400;700&display=swap');
        body {
            font-family: 'Lexend', sans-serif;
            background-color: #f0f9ff;
        }
        .card-bounce:hover {
            transform: translateY(-5px);
            transition: all 0.3s ease;
        }
        .correct-anim {
            animation: pulse 0.5s ease-in-out;
        }
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center p-4">

    <!-- 標題區域 -->
    <header class="text-center my-6">
        <h1 class="text-3xl font-bold text-blue-600">英文詞彙温習</h1>
        <h2 class="text-xl text-gray-700 mt-2">Dictation 16: Nature Vocabulary (Part B)</h2>
    </header>

    <!-- 遊戲控制台 -->
    <div id="game-container" class="w-full max-w-4xl bg-white rounded-3xl shadow-xl p-6 border-4 border-blue-200">
        
        <!-- 導航按鈕 -->
        <div class="flex justify-center gap-4 mb-8">
            <button onclick="showStudyMode()" id="study-btn" class="px-6 py-2 bg-blue-500 text-white rounded-full font-bold hover:bg-blue-600 transition">
                學習模式 (Study)
            </button>
            <button onclick="startQuizMode()" id="quiz-btn" class="px-6 py-2 bg-purple-500 text-white rounded-full font-bold hover:bg-purple-600 transition">
                挑戰模式 (Quiz)
            </button>
        </div>

        <!-- 學習模式介面 -->
        <div id="study-mode" class="grid grid-cols-2 sm:grid-cols-5 gap-4">
            <!-- 由 JS 生成 -->
        </div>

        <!-- 挑戰模式介面 -->
        <div id="quiz-mode" class="hidden text-center">
            <div class="mb-6">
                <p class="text-lg text-gray-600">聽聲音，選出正確的單字！</p>
                <div class="flex justify-center items-center gap-4 mt-4">
                    <button onclick="playTargetWord()" class="bg-yellow-400 p-4 rounded-full shadow-lg hover:bg-yellow-500 transition">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
                    </button>
                    <span id="score-display" class="text-2xl font-bold text-orange-500">得分: 0</span>
                </div>
            </div>
            <div id="quiz-options" class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                <!-- 由 JS 生成 -->
            </div>
        </div>

        <!-- 反饋訊息 -->
        <div id="feedback" class="fixed bottom-10 left-1/2 transform -translate-x-1/2 px-8 py-3 rounded-full text-white font-bold opacity-0 transition-opacity duration-300">
        </div>
    </div>

    <script>
        const vocab = [
            { id: 1, word: "hills", emoji: "⛰️" },
            { id: 2, word: "mountains", emoji: "🏔️" },
            { id: 3, word: "rivers", emoji: "🏞️" },
            { id: 4, word: "seas", emoji: "🌊" },
            { id: 5, word: "clouds", emoji: "☁️" },
            { id: 6, word: "stars", emoji: "⭐" },
            { id: 7, word: "trees", emoji: "🌳" },
            { id: 8, word: "the sky", emoji: "☀️" },
            { id: 9, word: "the moon", emoji: "🌙" },
            { id: 10, word: "the sun", emoji: "🌞" }
        ];

        let score = 0;
        let currentTarget = null;
        let isQuizMode = false;

        // 初始化學習模式
        function initStudy() {
            const container = document.getElementById('study-mode');
            container.innerHTML = '';
            vocab.forEach(item => {
                const card = document.createElement('div');
                card.className = 'bg-blue-50 p-4 rounded-xl text-center cursor-pointer card-bounce border-2 border-transparent hover:border-blue-300';
                card.innerHTML = `
                    <div class="text-4xl mb-2">${item.emoji}</div>
                    <div class="font-bold text-blue-800 text-lg">${item.word}</div>
                `;
                card.onclick = () => speak(item.word);
                container.appendChild(card);
            });
        }

        function speak(text) {
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'en-US';
            utterance.rate = 0.8; // 稍微慢一點方便小學生聽
            window.speechSynthesis.speak(utterance);
        }

        function showStudyMode() {
            isQuizMode = false;
            document.getElementById('study-mode').classList.remove('hidden');
            document.getElementById('quiz-mode').classList.add('hidden');
            document.getElementById('study-btn').classList.add('bg-blue-500');
            document.getElementById('quiz-btn').classList.replace('bg-purple-700', 'bg-purple-500');
            initStudy();
        }

        function startQuizMode() {
            isQuizMode = true;
            score = 0;
            document.getElementById('score-display').innerText = `得分: ${score}`;
            document.getElementById('study-mode').classList.add('hidden');
            document.getElementById('quiz-mode').classList.remove('hidden');
            document.getElementById('quiz-btn').classList.add('bg-purple-700');
            document.getElementById('study-btn').classList.replace('bg-blue-500', 'bg-blue-300');
            nextQuestion();
        }

        function nextQuestion() {
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';
            
            // 隨機選一個目標
            currentTarget = vocab[Math.floor(Math.random() * vocab.length)];
            
            // 隨機選 4 個選項（包含目標）
            let options = [...vocab].sort(() => 0.5 - Math.random()).slice(0, 4);
            if (!options.find(o => o.id === currentTarget.id)) {
                options[0] = currentTarget;
            }
            options.sort(() => 0.5 - Math.random());

            options.forEach(item => {
                const btn = document.createElement('button');
                btn.className = 'bg-white border-2 border-purple-200 p-6 rounded-2xl text-xl font-bold hover:bg-purple-50 transition active:scale-95';
                btn.innerText = item.word;
                btn.onclick = () => checkAnswer(item);
                optionsContainer.appendChild(btn);
            });

            setTimeout(() => playTargetWord(), 500);
        }

        function playTargetWord() {
            if (currentTarget) speak(currentTarget.word);
        }

        function checkAnswer(selected) {
            const feedback = document.getElementById('feedback');
            if (selected.id === currentTarget.id) {
                score++;
                document.getElementById('score-display').innerText = `得分: ${score}`;
                showFeedback("答對了！太棒了！", "bg-green-500");
                speak("Correct!");
                setTimeout(nextQuestion, 1200);
            } else {
                showFeedback("再試一次看看！", "bg-red-500");
                speak("Try again");
            }
        }

        function showFeedback(text, colorClass) {
            const feedback = document.getElementById('feedback');
            feedback.innerText = text;
            feedback.className = `fixed bottom-10 left-1/2 transform -translate-x-1/2 px-8 py-3 rounded-full text-white font-bold transition-opacity duration-300 ${colorClass} opacity-100`;
            setTimeout(() => {
                feedback.classList.replace('opacity-100', 'opacity-0');
            }, 1000);
        }

        // 頁面加載後初始化
        window.onload = initStudy;
    </script>
</body>
</html>
